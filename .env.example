# Vault Configuration
export VAULT_ADDR=http://vault.localhost:8200
export VAULT_TOKEN=
export VAULT_LICENSE=

# Authentik Configuration
# AUTO-GENERATED: setup-admin.sh will generate this if set to CHANGE_ME_GENERATE_RANDOM_KEY
# Or manually generate with: openssl rand -base64 32
AUTHENTIK_SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_KEY
AUTHENTIK_BOOTSTRAP_PASSWORD=admin
AUTHENTIK_BOOTSTRAP_TOKEN=

# PostgreSQL Configuration (for Authentik)
PG_PASS=CHANGE_ME_GENERATE_RANDOM_PASSWORD
PG_USER=authentik
PG_DB=authentik

# Authentik Version Pinning
AUTHENTIK_IMAGE=ghcr.io/goauthentik/server
AUTHENTIK_TAG=2026.2.2

# Authentik Admin Configuration (required for setup-admin.sh)
# REQUIRED: Set this password before running setup-admin.sh
AUTHENTIK_ADMIN_PASSWORD=CHANGE_ME_REQUIRED
# OPTIONAL: Admin username (defaults to 'akadmin' if not set)
AUTHENTIK_ADMIN_USER=akadmin

# Authentik Provider Configuration (used by Terraform)
export AUTHENTIK_URL=http://localhost:9000
# AUTO-GENERATED: This token is automatically created and populated by setup-admin.sh
# Do not set this manually - leave empty or with placeholder
export AUTHENTIK_TOKEN=
